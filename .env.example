# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Anthropic API for Claude 3.5 Sonnet (REQUIRED)
# Sign up at: https://console.anthropic.com/
# Used for AI contract auditing and legal analysis
ANTHROPIC_API_KEY="sk-ant-api03-..."

# OpenAI API for Embeddings (REQUIRED for production)
# Sign up at: https://platform.openai.com/api-keys
# Used for vector embeddings in RAG pipeline
OPENAI_API_KEY="sk-..."

# Email Notifications via Resend (REQUIRED)
# Sign up at: https://resend.com/
# Used for client and attorney notifications
RESEND_API_KEY="re_..."

# Paystack Payment Gateway (REQUIRED)
# Sign up at: https://dashboard.paystack.com/
# Supports South Africa, Kenya, and Nigeria
PAYSTACK_SECRET_KEY="sk_test_... or sk_live_..."
PAYSTACK_PUBLIC_KEY="pk_test_... or pk_live_..."

# Optional: Add your custom domain for email links
VITE_APP_URL="https://monogamy.legal"
